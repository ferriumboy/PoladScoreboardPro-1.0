rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: tournaments
    // Document ID: tournamentId
    // Fields:
    //   - id: string (required)
    //   - pin: string (required)
    //   - adminId: string (required)
    //   - state: map (required) - Full tournament state
    //   - createdAt: timestamp (optional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTournamentAdmin(tournamentId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminId;
    }

    match /tournaments/{tournamentId} {
      // Anyone can read if they know the ID (or PIN via query)
      allow read: if true; 
      
      // Only authenticated users can create
      allow create: if isAuthenticated() && request.resource.data.adminId == request.auth.uid;
      
      // Only the admin can update
      allow update: if isAuthenticated() && resource.data.adminId == request.auth.uid;
      
      allow delete: if isAuthenticated() && resource.data.adminId == request.auth.uid;
    }
  }
}
