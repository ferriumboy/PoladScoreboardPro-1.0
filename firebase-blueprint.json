{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Represents a multiplayer tournament session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pin": { "type": "string" },
        "adminId": { "type": "string" },
        "state": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "pin", "adminId", "state"]
    }
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Main tournament document"
    }
  }
}
